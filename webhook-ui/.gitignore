# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
# IDE ve Editörler (Sizin bilgisayarınızdaki kişisel ayarların gitmesini engeller)
.idea/
.vscode/
*.swp
*.swo

# İşletim Sistemi Kalıntıları (Özellikle Windows ve Mac kullanıcıları için)
Thumbs.db
ehthumbs.db
Desktop.ini
.Trashes
